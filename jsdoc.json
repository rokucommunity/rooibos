{
    "plugins": [
        "plugins/markdown",
        "./node_modules/brighterscript-jsdocs-plugin/convert-brighterscript-docs.js"
    ],
    "source": {
        "include": [
            "framework/src"
        ],
        "exclude": [
            "framework/src/roku_modules"
        ],
        "includePattern": ".+\\.br?s$",
        "excludePattern": "roku_modules"
    },
    "templates": {
        "referenceTitle": "Rooibos"
    },
    "opts": {
        "recurse": true,
        "template": "./node_modules/docdash",
        "brighterscript-jsdocs-plugin": {
            "addModule": false
        }
    },
    "docdash": {
        "menu": {
            "HOME": {
                "href": "../index.html",
                "id": "home"
            }
        },
        "sectionOrder": [
            "Namespaces",
            "Classes",
            "Interfaces"
        ]
    }
}
